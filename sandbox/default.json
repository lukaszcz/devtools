{
  "network": {
    "allowedDomains": [
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg"
    ],
    "allowWrite": [
      ".",
      "/tmp"
    ],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
